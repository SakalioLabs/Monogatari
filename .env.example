# Monogatari Engine - Environment Configuration
# Copy this file to .env and fill in your values

# AI Backend (OpenAI-compatible API)
MONOGATARI_AI_PROVIDER=api
MONOGATARI_AI_BASE_URL=https://api.openai.com/v1
MONOGATARI_AI_API_KEY=sk-your-key-here
MONOGATARI_AI_MODEL=gpt-4o-mini

# TTS Provider (system|azure|elevenlabs)
MONOGATARI_TTS_PROVIDER=system
MONOGATARI_TTS_AZURE_KEY=
MONOGATARI_TTS_AZURE_REGION=eastus
MONOGATARI_TTS_ELEVENLABS_KEY=
MONOGATARI_TTS_ELEVENLABS_VOICE=21m00Tcm4TlvDq8ikWAM

# Cloud Sync (optional)
MONOGATARI_SYNC_ENDPOINT=
MONOGATARI_SYNC_TOKEN=

# Project Data Path
MONOGATARI_DATA_PATH=./data