{
  "name": "llm-galgame-frontend",
  "private": true,
  "version": "0.9.5",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build && node scripts/prepare-web-dist.mjs && node scripts/verify-bundle-budget.mjs && node scripts/verify-responsive-shell.mjs",
    "build:web": "vue-tsc --noEmit && vite build && node scripts/prepare-web-dist.mjs && node scripts/verify-bundle-budget.mjs && node scripts/verify-responsive-shell.mjs",
    "verify:mobile-readiness": "node scripts/verify-mobile-readiness.mjs",
    "verify:responsive-shell": "node scripts/verify-responsive-shell.mjs",
    "verify:renderer-assets": "node scripts/verify-renderer-assets.mjs",
    "verify:web-budget": "node scripts/verify-bundle-budget.mjs",
    "preview:web": "vite preview --host 127.0.0.1",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "2.7.1",
    "pinia": "^2.1.0",
    "pixi-live2d-display": "^0.4.0",
    "pixi.js": "^7.3.0",
    "three": "^0.185.1",
    "vue": "^3.4.0",
    "vue-router": "^4.2.0"
  },
  "overrides": {
    "pixi-live2d-display": {
      "gh-pages": "^6.3.0"
    }
  },
  "devDependencies": {
    "@types/three": "^0.185.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vue-tsc": "^3.3.6"
  }
}
