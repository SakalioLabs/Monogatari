{
  "name": "llm-galgame-frontend",
  "private": true,
  "version": "0.9.5",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "prebuild": "npm run test:unit",
    "build": "npm run verify:i18n && vue-tsc --noEmit && vite build && node scripts/prepare-web-dist.mjs && node scripts/verify-inference-runtime.mjs && node scripts/verify-bundle-budget.mjs && node scripts/verify-responsive-shell.mjs && node scripts/verify-mobile-readiness.mjs",
    "build:web": "npm run verify:i18n && vue-tsc --noEmit && vite build && node scripts/prepare-web-dist.mjs && node scripts/verify-inference-runtime.mjs && node scripts/verify-bundle-budget.mjs && node scripts/verify-responsive-shell.mjs && node scripts/verify-mobile-readiness.mjs",
    "sync:locales": "node scripts/sync-locales.mjs --write",
    "verify:i18n": "node scripts/sync-locales.mjs && node scripts/verify-i18n-coverage.mjs",
    "verify:inference-runtime": "node scripts/verify-inference-runtime.mjs",
    "verify:mobile-readiness": "node scripts/verify-mobile-readiness.mjs",
    "verify:responsive-shell": "node scripts/verify-responsive-shell.mjs",
    "verify:renderer-assets": "node scripts/verify-renderer-assets.mjs",
    "verify:web-budget": "node scripts/verify-bundle-budget.mjs",
    "preview:web": "vite preview --host 127.0.0.1",
    "preview": "vite preview"
  },
  "dependencies": {
    "@huggingface/transformers": "4.2.0",
    "@lucide/vue": "^1.24.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "2.7.1",
    "pinia": "^2.1.0",
    "pixi-live2d-display": "^0.4.0",
    "pixi.js": "^7.3.0",
    "three": "^0.185.1",
    "vue": "^3.4.0",
    "vue-router": "^4.2.0"
  },
  "overrides": {
    "adm-zip": "0.6.0",
    "sharp": "0.35.3",
    "pixi-live2d-display": {
      "gh-pages": "^6.3.0"
    }
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "2.4.11",
    "esbuild": "^0.28.1",
    "happy-dom": "20.10.6",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "4.1.10",
    "vue-tsc": "^3.3.6"
  }
}
