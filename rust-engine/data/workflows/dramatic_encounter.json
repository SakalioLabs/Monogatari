    {"id": "choice1", "node_type": "choice", "label": "Choose Path", "x": 1500, "y": 300, "config": {"choices": ["Show me the restless books", "I came for knowledge, not riddles", "Is there danger here?"]}, "connections": ["sfx1", "d3", "d4"]},
