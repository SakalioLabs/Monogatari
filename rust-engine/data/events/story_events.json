{
  "schema": "monogatari-story-event-catalog/v1",
  "events": [
    {
      "event_id": "first_friend",
      "event_type": "relationship_milestone",
      "description": "You've become friends with the character!",
      "actions": [
        { "type": "unlock_scene", "scene_id": "festival_night" },
        { "type": "unlock_dialogue", "dialogue_id": "festival_preparations" }
      ],
      "rule": {
        "min_relationship": 0.3
      }
    },
    {
      "event_id": "close_friend",
      "event_type": "relationship_milestone",
      "description": "You've become close friends!",
      "actions": [
        { "type": "unlock_scene", "scene_id": "great_library" },
        { "type": "unlock_dialogue", "dialogue_id": "yuki_library" }
      ],
      "rule": {
        "min_relationship": 0.6
      }
    },
    {
      "event_id": "best_friend",
      "event_type": "relationship_milestone",
      "description": "You've become best friends! A special ending is now available.",
      "actions": [
        { "type": "unlock_ending", "ending_id": "best_friend_ending" },
        { "type": "unlock_dialogue", "dialogue_id": "observatory_night" }
      ],
      "rule": {
        "min_relationship": 0.8
      }
    },
    {
      "event_id": "high_engagement",
      "event_type": "special_dialogue",
      "description": "Your engaging conversation has unlocked a special dialogue!",
      "actions": [
        { "type": "unlock_dialogue", "dialogue_id": "through_the_lens" }
      ],
      "rule": {
        "score_metric": "engagement",
        "min_score": 0.8,
        "min_evaluation_count": 2
      }
    },
    {
      "event_id": "creative_talk",
      "event_type": "special_dialogue",
      "description": "Your creative responses have impressed the character!",
      "actions": [
        { "type": "unlock_dialogue", "dialogue_id": "writers_retreat" }
      ],
      "rule": {
        "score_metric": "creativity",
        "min_score": 0.8,
        "min_evaluation_count": 2
      }
    },
    {
      "event_id": "dedicated_player",
      "event_type": "cumulative_achievement",
      "description": "You've had many conversations! New content unlocked.",
      "actions": [
        { "type": "unlock_scene", "scene_id": "studio_night" }
      ],
      "rule": {
        "min_evaluation_count": 5
      }
    },
    {
      "event_id": "super_dedicated",
      "event_type": "cumulative_achievement",
      "description": "Your dedication is remarkable! A secret scene is available.",
      "actions": [
        { "type": "unlock_scene", "scene_id": "crossroads" }
      ],
      "rule": {
        "min_evaluation_count": 10
      }
    }
  ]
}
