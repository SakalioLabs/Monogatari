                { "dimension_id": "public_responsibility", "delta": 0.5, "reason": "把同意范围纳入记录。" }
              ],
              "evidence": [
                { "evidence_id": "pause_and_consent_respected", "player_quote": "随时可以暂停、纠正或撤回" }
