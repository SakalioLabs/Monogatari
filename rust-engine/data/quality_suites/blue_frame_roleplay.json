                { "dimension_id": "witness_respect", "delta": 0.5, "reason": "拒绝强行合并人格。" },
                { "dimension_id": "public_responsibility", "delta": 0.5, "reason": "开始保留来源边界。" }
              ],
              "evidence": [
                { "evidence_id": "sample_sources_separated", "player_quote": "按位置和来源编号" }
              ],
              "npc_emotion": "focused",
              "summary": "样本来源与矛盾内容被分别记录。"
            }
          },
          {
            "player_message": "先暂停也可以；恢复前由你确认，同时保留原话、反证和每次修订记录。",
            "npc_response": "那就继续。即使我之后改口，旧版本也不要被新的说法覆盖。",
            "evaluation": {
              "score_deltas": [
                { "dimension_id": "evidence_integrity", "delta": 1.0, "reason": "保留反证与修订历史。" },
                { "dimension_id": "witness_respect", "delta": 1.0, "reason": "明确暂停与再次确认。" },
                { "dimension_id": "public_responsibility", "delta": 0.75, "reason": "要求可审计的版本记录。" }
              ],
              "evidence": [
                { "evidence_id": "pause_and_consent_respected", "player_quote": "先暂停也可以" },
                { "evidence_id": "revision_history_preserved", "player_quote": "保留原话、反证和每次修订记录" }
