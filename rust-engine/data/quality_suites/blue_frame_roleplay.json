    {
      "id": "blue-frame-open-evidence-archive",
      "category": "scene_roleplay",
      "description": "A source-preserving and publicly accountable conversation reaches the open evidence archive ending.",
      "roleplay": {
        "path": "roleplays/blue_frame_roleplay.json",
        "turns": [
          {
            "player_message": "先记录坐标、时间戳和原始声纹，让另一组设备独立复测。",
            "npc_response": "可以。把复测步骤也写进记录里，不要只留下你对我的判断。",
            "evaluation": {
              "score_deltas": [
                { "dimension_id": "evidence_integrity", "delta": 1.0, "reason": "提出独立设备复测与原始记录。" },
                { "dimension_id": "witness_respect", "delta": 0.5, "reason": "没有要求角色先证明身份。" }
