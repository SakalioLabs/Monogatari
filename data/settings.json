{
    "engine": {
        "title": "LLM Galgame Engine",
        "width": 1280,
        "height": 720,
        "targetFps": 60,
        "fullscreen": false
    },
    "rendering": {
        "vsync": true,
        "defaultFont": "default",
        "fontSize": 18,
        "titleFontSize": 36
    },
    "dialogue": {
        "typewriterSpeed": 30,
        "autoAdvanceDelay": 0,
        "defaultBackgroundAlpha": 200
    },
    "ai": {
        "provider": "api",
        "api": {
            "baseUrl": "https://api.openai.com/v1",
            "apiKey": "",
            "model": "gpt-3.5-turbo",
            "maxTokens": 512,
            "temperature": 0.7
        },
        "onnx": {
            "modelPath": "models/model.onnx",
            "tokenizerPath": "models/tokenizer.json",
            "useDirectML": true,
            "maxSequenceLength": 2048
        }
    },
    "paths": {
        "characters": "characters",
        "knowledge": "knowledge",
        "dialogue": "dialogue",
        "scenes": "scenes",
        "assets": "assets",
        "events": "events",
        "saves": "saves",
        "quality_suites": "quality_suites"
    }
}
